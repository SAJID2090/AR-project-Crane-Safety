using UnityEngine;
using UnityEngine.SceneManagement;

public class AppSceneLoader : MonoBehaviour
{
    [SerializeField] private string viewerSceneName = "ViewerScene";
    [SerializeField] private string arSceneName = "ARScene";

    public void OpenViewer()
    {
        SceneManager.LoadScene(viewerSceneName);
    }

    public void OpenAR()
    {
        SceneManager.LoadScene(arSceneName);
    }
}
