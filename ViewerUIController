using UnityEngine;
using UnityEngine.UI;
using TMPro;

public class ViewerUIController : MonoBehaviour
{
    [Header("UI")]
    [SerializeField] private Button btnAR;
    [SerializeField] private Button btnBG;
    [SerializeField] private Button btnScreenshot;
    [SerializeField] private TMP_Text txtTitle;

    [Header("Background")]
    [SerializeField] private Camera viewerCamera;

    [Header("Managers")]
    [SerializeField] private AppSceneLoader sceneLoader;
    [SerializeField] private ScreenshotManager screenshotManager;

    private int bgIndex = 0;

    void Start()
    {
        if (viewerCamera == null) viewerCamera = Camera.main;

        if (btnAR != null) btnAR.onClick.AddListener(() => sceneLoader.OpenAR());
        if (btnBG != null) btnBG.onClick.AddListener(CycleBackground);
        if (btnScreenshot != null) btnScreenshot.onClick.AddListener(() => screenshotManager.TakeScreenshot());

        // default nice background
        ApplyBackground(0);
    }

    private void CycleBackground()
    {
        bgIndex = (bgIndex + 1) % 3;
        ApplyBackground(bgIndex);
    }

    private void ApplyBackground(int index)
    {
        if (viewerCamera == null) return;

        // 0: grey, 1: dark grey, 2: light blue
        if (index == 0) viewerCamera.backgroundColor = new Color(0.6f, 0.6f, 0.6f, 1f);
        if (index == 1) viewerCamera.backgroundColor = new Color(0.15f, 0.15f, 0.15f, 1f);
        if (index == 2) viewerCamera.backgroundColor = new Color(0.65f, 0.8f, 0.95f, 1f);
    }
}
